# ── Zip / archive artifacts ──────────────────────────────────
bill_review_app_src.zip
*.zip

# ── Caches ───────────────────────────────────────────────────
node_modules/
__pycache__/
*.pyc
*.log

# ── Local temp files ─────────────────────────────────────────
C:temp*.json

# ── Secrets ──────────────────────────────────────────────────
secrets/

# ── Claude local settings ───────────────────────────────────
.claude/settings.local.json

# ── Pip metadata (everywhere) ───────────────────────────────
**/*.dist-info/

# ── Vendored dependency directories ─────────────────────────
**/vendor/
**/layer_build/

# ── Build directory (keep build_vendor_cache.py) ─────────────
build/*
!build/build_vendor_cache.py

# ── Deploy build artifacts ───────────────────────────────────
bill_review_app/deploy/aws/build/
deploy/aws/build/

